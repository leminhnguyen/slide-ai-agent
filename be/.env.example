# ── LLM ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WEB_SEARCH_MODEL=gpt-5

# ── MongoDB ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://root:example@app_mongo:27017/?authSource=admin
MONGODB_DB=slide_agent

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Marp CLI (export) ────────────────────────────────────────────────
# Path to marp-cli binary (installed via npm install -g @marp-team/marp-cli)
MARP_CLI_PATH=marp

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:80
